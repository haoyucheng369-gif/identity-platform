      },
      {
        "Username": "user",
        "Password": "user123",
        "Role": "User",
        "Scopes": [ "content.read" ]
      }
    ],
    "Clients": [
      {
        "ClientId": "worker-service",
        "ClientSecret": "worker-secret",
        "Scopes": [ "content.read", "content.write" ]
      }
    ]
  },
  "AllowedHosts": "*"
}
