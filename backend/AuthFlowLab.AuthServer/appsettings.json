{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "auth-flow-lab",
    "Audience": "api-server",
    "PrivateKeyPath": "../../keys/private.key"
  },
  "Auth": {
    "AccessTokenMinutes": 30,
    "Users": [
      {
        "Username": "admin",
        "Password": "admin123",
        "Role": "Admin",
